<?xml version="1.0" encoding="ISO-8859-1"?>
<project name="rename" default="rename">
  <!--
  Examples:

    ant -f rename.xml -Dcurrent=3.0.0 -Drelease=3.1.0
    ant -f rename.xml -Dcurrent=3.0.0 -Drelease=3.1.0 -Dgt.current=35 -Dgt.release=36 -Dgwc.current=2.0 -Dgwc.release=2.1
  -->
  <tstamp/>
  <property name="current"       value="3.0.0"/>
  <property name="release"       value="3.1.0"/>
  <property name="current.minor" value="3.0"/>
  <property name="release.minor" value="3.1"/>
  <property name="gt.current"    value="35"/>
  <property name="gt.release"    value="36"/>
  <property name="gwc.current"   value="2.0"/>
  <property name="gwc.release"   value="2.1"/>

  <target name="test">
     <echo>current: ${current} (minor: ${current.minor})</echo>
     <echo>release: ${release} (minor: ${release.minor})</echo>
     <echo>gt.current: ${gt.current} -&gt; gt.release: ${gt.release}</echo>
     <echo>gwc.current: ${gwc.current} -&gt; gwc.release: ${gwc.release}</echo>
  </target>

  <target name="rename"
          description="Update version references for a new branch">
    <replace dir="..">
      <include name="**/pom.xml"/>
      <include name="src/release/bin.xml"/>
      <include name="src/release/installer/win/GeoServerEXE.nsi"/>
      <include name="src/release/installer/win/wrapper.conf"/>
      <replacefilter token="${current}-SNAPSHOT" value="${release}-SNAPSHOT"/>
    </replace>
    <!-- version.py sits at doc/version.py (outside doc/en); has both full and minor version defaults -->
    <replace dir="../doc">
      <include name="version.py"/>
      <replacefilter token="${current}" value="${release}"/>
      <replacefilter token="${current.minor}" value="${release.minor}"/>
    </replace>
    <replace dir="..">
      <include name="src/pom.xml"/>
      <replacefilter token="${gt.current}-SNAPSHOT" value="${gt.release}-SNAPSHOT"/>
      <replacefilter token="${gwc.current}-SNAPSHOT" value="${gwc.release}-SNAPSHOT"/>
    </replace>
  </target>

</project>

