<assembly>
  <id>backup-restore-plugin</id>
  <formats>
    <format>zip</format>
  </formats>
  <includeBaseDirectory>false</includeBaseDirectory>
  <fileSets>
    <fileSet>
      <directory>target/dependency</directory>
      <outputDirectory></outputDirectory>
      <includes>
         <include>gs-backup-restore-web*.jar</include>
         <include>gs-backup-restore-extension*.jar</include>
         <include>gs-backup-restore-core*.jar</include>
         <include>gs-backup-restore-rest*.jar</include>
         <!-- Module libraries not provided by the base GeoServer WAR -->
         <include>commons-exec*.jar</include>
         <include>commons-lang3*.jar</include>
         <include>commons-vfs2*.jar</include>
         <include>prettytime*.jar</include>
         <include>jdom*.jar</include>
         <!-- Spring Batch 6 runtime (job engine) -->
         <include>spring-batch-core*.jar</include>
         <include>spring-batch-infrastructure*.jar</include>
         <include>spring-batch-integration*.jar</include>
         <!-- Spring Batch 6 embedded H2 job repository -->
         <include>h2-*.jar</include>
         <!-- Spring Batch 6 observability (compile dependency of spring-batch-core) -->
         <include>micrometer-observation-*.jar</include>
         <include>micrometer-commons-*.jar</include>
         <include>micrometer-core-*.jar</include>
         <!-- spring-integration-core 7 and its reactive dependencies -->
         <include>spring-integration-core*.jar</include>
         <include>spring-messaging*.jar</include>
         <include>spring-retry*.jar</include>
         <include>reactor-core-*.jar</include>
         <include>reactive-streams-*.jar</include>
      </includes>
      <excludes>
      </excludes>
    </fileSet>
  </fileSets>
</assembly>
