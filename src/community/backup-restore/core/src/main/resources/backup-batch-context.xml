<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:jdbc="http://www.springframework.org/schema/jdbc"
	xsi:schemaLocation="
		http://www.springframework.org/schema/beans
		http://www.springframework.org/schema/beans/spring-beans.xsd
		http://www.springframework.org/schema/jdbc
		http://www.springframework.org/schema/jdbc/spring-jdbc.xsd">

	<!--
	  In-memory batch infrastructure (Spring Batch 6).

	  Spring Batch 5 removed the Map-based in-memory JobRepository / JobExplorer factory beans. The
	  official replacement for a non-persistent yet fully queryable repository is an embedded database
	  seeded with the standard Batch metadata schema (see the Spring Batch migration guide). Backup /
	  Restore needs a *queryable* repository: it enumerates running executions to forbid concurrent
	  jobs (Backup#getBackupRunningExecutions / #getRestoreRunningExecutions) and supports stop, restart
	  and abandon through the JobOperator. A ResourcelessJobRepository keeps no metadata and therefore
	  cannot satisfy any of those, so an embedded H2 database is used instead. The database is recreated
	  on every startup, preserving the original semantics: job metadata lives only for the lifetime of
	  the JVM and never touches the data directory.

	  In Spring Batch 6 the JobExplorer is merged into the JobRepository and the JobLauncher into the
	  JobOperator, so no separate JobExplorer / JobLauncher beans are required.
	-->
	<jdbc:embedded-database id="backupJobRepositoryDataSource" type="H2" generate-name="true">
		<jdbc:script location="classpath:org/springframework/batch/core/schema-h2.sql" />
	</jdbc:embedded-database>

	<bean id="transactionManager" class="org.springframework.jdbc.support.JdbcTransactionManager">
		<constructor-arg ref="backupJobRepositoryDataSource" />
	</bean>

	<bean id="jobRepository" class="org.springframework.batch.core.repository.support.JobRepositoryFactoryBean">
		<property name="dataSource" ref="backupJobRepositoryDataSource" />
		<property name="transactionManager" ref="transactionManager" />
		<!-- H2 does not support SERIALIZABLE create semantics well; READ_COMMITTED is sufficient here -->
		<property name="isolationLevelForCreate" value="ISOLATION_READ_COMMITTED" />
	</bean>

	<bean id="jobRegistry" class="org.springframework.batch.core.configuration.support.MapJobRegistry" />

	<!-- auto-registers the Job beans by name into the job registry (replaces JobRegistryBeanPostProcessor) -->
	<bean class="org.springframework.batch.core.configuration.support.JobRegistrySmartInitializingSingleton">
		<property name="jobRegistry" ref="jobRegistry" />
	</bean>

	<!-- asynchronous job launcher (TaskExecutorJobLauncher replaces the removed SimpleJobLauncher) -->
	<bean id="jobLauncherAsync" class="org.springframework.batch.core.launch.support.TaskExecutorJobLauncher">
		<property name="jobRepository" ref="jobRepository" />
		<property name="taskExecutor">
			<bean class="org.springframework.core.task.SimpleAsyncTaskExecutor">
				<property name="concurrencyLimit" value="10" />
			</bean>
		</property>
	</bean>

	<!-- job operator for monitoring / stop / restart / abandon of running executions -->
	<bean id="jobOperator" class="org.springframework.batch.core.launch.support.JobOperatorFactoryBean">
		<property name="jobRepository" ref="jobRepository" />
		<property name="jobRegistry" ref="jobRegistry" />
		<property name="transactionManager" ref="transactionManager" />
		<property name="taskExecutor">
			<bean class="org.springframework.core.task.SimpleAsyncTaskExecutor">
				<property name="concurrencyLimit" value="10" />
			</bean>
		</property>
	</bean>

</beans>
