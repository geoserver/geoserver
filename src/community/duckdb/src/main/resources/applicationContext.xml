<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
             http://www.springframework.org/schema/beans
             http://www.springframework.org/schema/beans/spring-beans.xsd">
  <bean id="duckDBExtension" class="org.geoserver.platform.ModuleStatusImpl">
    <property name="module" value="gs-duckdb"/>
    <property name="name" value="DuckDB DataStore Extension"/>
    <property name="component" value="DuckDB datastore extension"/>
    <property name="documentation" value="community/duckdb/index.html"/>
    <!-- Driver jars are shipped with the extension package, so availability is unconditional. -->
    <property name="available" value="true"/>
    <property name="enabled" value="true"/>
    <property name="category" value="COMMUNITY"/>
  </bean>
</beans>
