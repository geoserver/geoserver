<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <parent>
    <groupId>org.geoserver</groupId>
    <artifactId>extension</artifactId>
    <version>3.0.0-SNAPSHOT</version>
  </parent>
  <groupId>org.geoserver.extension</groupId>
  <artifactId>gs-wcs</artifactId>
  <packaging>pom</packaging>
  <name>GeoServer WCS Extensions</name>

  <profiles>
    <!-- allExtensions profile, includes all modules -->
    <profile>
      <id>allExtensions</id>
      <modules>
        <module>wcs1_0</module>
        <module>wcs1_1</module>
        <module>wcs-integration</module>
      </modules>
    </profile>

    <!-- release profile, includes all modules -->
    <profile>
      <id>release</id>
      <modules>
        <module>wcs1_0</module>
        <module>wcs1_1</module>
        <module>wcs-integration</module>
      </modules>
    </profile>

    <profile>
      <id>wcs</id>
      <modules>
        <module>wcs1_0</module>
        <module>wcs1_1</module>
        <module>wcs-integration</module>
      </modules>
    </profile>

    <profile>
      <id>wcs11</id>
      <activation>
        <property>
          <!-- used as test dependency -->
          <name>!maven.test.skip</name>
        </property>
      </activation>
      <modules>
        <module>wcs1_1</module>
      </modules>
    </profile>

    <profile>
      <id>wcs10</id>
      <activation>
        <property>
          <!-- used as test dependency -->
          <name>!maven.test.skip</name>
        </property>
      </activation>
      <modules>
        <module>wcs1_0</module>
      </modules>
    </profile>
  </profiles>

</project>
